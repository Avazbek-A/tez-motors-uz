# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (REQUIRED, server-only — never expose to the browser).
# Privileged writes and every PII/money table read go through this; without it
# admin, orders, payments, accounts, and cron routes cannot function.
SUPABASE_SERVICE_ROLE_KEY=

# Admin login password (REQUIRED). Verified in src/lib/auth.ts. Rotate before
# handoff and deliver the new value via 1Password / signed PDF — never Telegram.
ADMIN_PASSWORD=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile bot protection (optional - public forms fail-open if unset).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: widget site key (browser). TURNSTILE_SECRET:
# server secret used to verify the token in src/lib/turnstile.ts. With both unset,
# forms still work (honeypot + rate limiter remain the gate).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Telegram Bot (optional - for inquiry notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional public channel (e.g. @tezmotors or a -100... id). When set, new
# available cars are auto-announced to it. Unset = no channel posts.
TELEGRAM_CHANNEL_ID=
# Operational alerts (optional). Where reportServerError / alertDealer send
# critical alerts (cron failures, payment-callback errors, notify-fanout
# failures). Falls back to TELEGRAM_CHAT_ID when unset; set to route ops alerts
# to a separate channel from customer-lead notifications.
TELEGRAM_ERROR_CHAT_ID=

# Transactional email via Resend (optional - fail-open if unset).
# RESEND_API_KEY: from resend.com. EMAIL_FROM: a sender on a domain verified
# in Resend (e.g. "Tez Motors <noreply@tezmotors.uz>"). DEALER_EMAIL: inbox
# that receives new-lead alerts (fallback when Telegram is down).
RESEND_API_KEY=
EMAIL_FROM=
DEALER_EMAIL=

# Scheduled jobs (optional - allows manual runs if unset).
# Shared bearer secret between the app and the separate cron Worker
# (cron-worker/). The cron Worker fires /api/cron/* on a schedule with
# "Authorization: Bearer <CRON_SECRET>"; src/lib/cron/guard.ts verifies it.
# When unset, the cron routes allow unauthenticated manual runs (dev only).
CRON_SECRET=

# Market price intelligence ingest (optional - fail-open if unset).
# Shared bearer secret an off-Workers collector (OLX + Telegram scrapers on your
# Vostro — see deploy/collector/) presents to POST scraped listings to
# /api/admin/market/ingest. Admin sessions can ingest without it; when unset,
# only the admin UI can add market data. See docs/MARKET_INTEL.md.
MARKET_INGEST_SECRET=

# Headless-browser media extractor (optional - fail-open to the static parser).
# Point at the local Playwright service (deploy/collector/extractor.mjs) to make
# image extraction work for JS-rendered, anti-bot galleries (AutoHome CN,
# AliExpress). Only reachable from the self-hosted/local app (not the Workers
# edge). EXTRACTOR_SECRET is the optional shared bearer the service checks.
EXTRACTOR_URL=
EXTRACTOR_SECRET=

# Self-host auto-deploy webhook (optional; see deploy/selfhost/SETUP.md §13).
# When set, deploy/selfhost/update-webhook.mjs accepts GitHub push events
# (HMAC SHA-256 verified) and runs deploy/selfhost/update.sh — turning
# `git push` into a live deploy on the Vostro. Telegram pings the dealer on
# success/failure (reuses TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID). Unset on
# Cloudflare Workers / non-self-host deployments.
UPDATE_WEBHOOK_SECRET=
DEPLOY_BRANCH=main

# AI assistant + all generative features (operator briefings, marketing copy,
# lead/supplier draft replies, market parsing). Optional — fail-open to templates.
#
# Two provider shapes, chosen by LLM_PROVIDER (or auto-detected from LLM_API_URL).
#
# RECOMMENDED — a HOSTED model. Edge-reachable (works on Cloudflare Workers), no
# always-on machine to keep up and cool, and at this volume the cost is pennies.
# Pick ONE:
#
#   Anthropic Haiku 4.5 (simplest; strong RU/UZ) — just set the key:
#   LLM_API_KEY=sk-ant-...
#   # LLM_PROVIDER / LLM_API_URL / LLM_MODEL optional; default = claude-haiku-4-5
#
#   Google Gemini Flash (cheapest; also does the spec VISION model in one provider):
#   LLM_PROVIDER=openai
#   LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_API_KEY=<gemini key>
#   LLM_MODEL=gemini-2.5-flash
#   # then set LLM_VISION_MODEL=gemini-2.5-flash too (below)
#
#   OpenRouter (RECOMMENDED — one key → every model, OpenAI-compatible, trivial
#   to swap/compare). DeepSeek V4 Flash is GA, ~$0.10/$0.20 per M tokens (≈free
#   at this volume), 1M context:
#       LLM_PROVIDER=openai
#       LLM_API_URL=https://openrouter.ai/api/v1
#       LLM_API_KEY=sk-or-...
#       LLM_MODEL=deepseek/deepseek-v4-flash
#     NOTE: deepseek-v4-flash is TEXT-ONLY — for AutoHome spec screenshots set a
#     vision model on the same key, e.g. LLM_VISION_MODEL=google/gemini-2.5-flash
#     (or qwen/qwen2.5-vl-..). (OpenRouter also accepts optional HTTP-Referer /
#     X-Title headers for its dashboard; not required — plain Bearer auth works.)
#
#   Any OpenAI-compatible host — set LLM_PROVIDER=openai + the /v1 URL + key +
#   LLM_MODEL. (Endpoints/model names drift — verify in the provider's docs.)
#     NVIDIA NIM (FREE tier, rate-limited — great for dev / low volume / a
#     bake-off; no SLA, so prefer a cheap paid one once leads flow):
#       LLM_API_URL=https://integrate.api.nvidia.com/v1   LLM_API_KEY=nvapi-...
#       LLM_MODEL=qwen/qwen2.5-7b-instruct   (or a deepseek/llama model)
#     DeepSeek (very cheap, strong):
#       LLM_API_URL=https://api.deepseek.com   LLM_MODEL=deepseek-chat
#     Alibaba Qwen / DashScope (cheap; same family as the old local qwen — good
#     RU/UZ; intl endpoint):
#       LLM_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#       LLM_MODEL=qwen-plus
#     Groq (fastest, cheap): LLM_API_URL=https://api.groq.com/openai/v1
#   Note: customer messages (name, car interest) transit the chosen provider —
#   for Chinese providers that's fine for this market, just a conscious choice.
#
# FALLBACK / DEV ONLY — local Ollama (free, private, but a box that must stay up
# AND cool; NOT recommended for production, and unreachable from the Workers edge):
#   LLM_PROVIDER=openai
#   LLM_API_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen2.5:7b-instruct
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=
# Vision model for reading car-spec screenshots (AutoHome CN). OpenAI-compatible
# path only. HOSTED: Gemini Flash (gemini-2.5-flash) or GPT-4o read images off
# the edge — no self-host box. Local Ollama alt: `ollama pull qwen2.5-vl`.
# Defaults to qwen2.5-vl if unset.
LLM_VISION_MODEL=

# AI auto-responder (optional). Set to 1 to auto-send a personalized AI-drafted
# reply to every lead that leaves an email (uses LLM_API_KEY; fail-open to a
# localized template, never invents prices). Empty = standard confirmation only.
AI_AUTORESPOND=

# Customer OTP via Eskiz.uz SMS (optional - fail-open if unset).
# ESKIZ_EMAIL / ESKIZ_PASSWORD: credentials from your eskiz.uz account.
# ESKIZ_FROM: an approved sender alphaname (defaults to Eskiz "4546" test
# sender). When unset, the phone-login OTP is logged server-side instead of
# sent, so the flow stays testable in dev without burning SMS credits.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=

# Web Push (optional - account push notifications fail-open / render nothing if
# unset). Generate a VAPID P-256 keypair once (Web Crypto / any vapid tool).
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY: base64url, server-side signing.
# VAPID_SUBJECT: a "mailto:" contact for push services.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY: same public key, exposed to the browser so the
# PushManager can subscribe. Without these, the notification toggle is hidden.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Telegram inbound bot (optional - the webhook no-ops cleanly if unset).
# Reuses the existing TELEGRAM_BOT_TOKEN above for sending replies. This secret
# is the value you pass as secret_token to setWebhook; the webhook rejects any
# request whose X-Telegram-Bot-Api-Secret-Token header doesn't match it.
# One-time registration after deploy:
#   curl "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/setWebhook" \
#     -d url="https://tezmotors.uz/api/bot/telegram" \
#     -d secret_token="<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_WEBHOOK_SECRET=

# Dealer Copilot over Telegram (optional). Comma-separated Telegram chat ids that
# are the DEALER's — messages from these run the operator copilot (ask the
# business anything + confirm-gated actions) instead of the customer recommender.
# Find your id by messaging the bot and reading chat.id in the webhook logs, or
# via @userinfobot. Leave empty to disable the operator branch entirely.
TELEGRAM_OPERATOR_CHAT_IDS=

# WhatsApp inbound bot via Meta Cloud API (optional - webhook no-ops if unset).
# WHATSAPP_VERIFY_TOKEN: a value you choose; entered in the Meta app dashboard as
# the webhook verify token (GET handshake echoes hub.challenge when it matches).
# WHATSAPP_TOKEN: a permanent System User access token for the WhatsApp Business
# Account. WHATSAPP_PHONE_ID: the phone number id that sends replies.
# Setup: set the callback URL to https://<your-domain>/api/bot/whatsapp, verify
# with WHATSAPP_VERIFY_TOKEN, then subscribe the WABA to the "messages" field.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# WHATSAPP_APP_SECRET: the Meta App secret. When set, inbound webhook POSTs must
# carry a valid X-Hub-Signature-256 (HMAC of the body) or they're rejected 401 —
# stops forged message events. Fail-open if unset (channel ships dark).
WHATSAPP_APP_SECRET=

# Payme (Paycom) online deposits (optional - ships dark if unset).
# PAYME_MERCHANT_ID / PAYME_MERCHANT_KEY: from the Payme merchant cabinet after
# onboarding. The key authenticates the JSON-RPC merchant endpoint
# (/api/payments/payme); without it auth fails closed and the endpoint is inert.
# NEXT_PUBLIC_PAYME_MERCHANT_ID: same merchant id, exposed to the browser so the
# "Pay deposit online" button renders. Without it the button is hidden.
# Configure the cabinet's account field as "order_id" and point the endpoint at
# https://<your-domain>/api/payments/payme.
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
NEXT_PUBLIC_PAYME_MERCHANT_ID=

# Click.uz online deposits (optional - second payment rail, ships dark if unset).
# CLICK_SERVICE_ID / CLICK_MERCHANT_ID: from the Click merchant cabinet after
# onboarding. CLICK_SECRET_KEY signs the Prepare/Complete callbacks
# (/api/payments/click); without it verifyClickSign fails closed and the endpoint
# is inert. NEXT_PUBLIC_CLICK_MERCHANT_ID: same merchant id, exposed to the browser
# so the "Pay with Click" button renders. Without it the button is hidden.
# In the cabinet, set the Prepare URL and Complete URL to
# https://<your-domain>/api/payments/click and the param name to "order_id".
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
NEXT_PUBLIC_CLICK_MERCHANT_ID=

# Multi-tenancy (Phase AV foundation — OFF by default; keep unset).
# Unset/0 = single-dealer mode: every request resolves to the default tenant and
# behavior is identical to today. Set to 1 ONLY after the query-scoping + RLS
# increments land (see docs/MULTI_TENANT.md) — turning it on early would scope
# reads against columns that aren't fully wired yet.
MULTI_TENANT=

# Analytics & live chat (all optional - fail-open / render nothing if unset).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN: domain registered in Plausible (loads the script).
# NEXT_PUBLIC_TAWK_ID: Tawk.to property/widget id "<propertyId>/<widgetId>".
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_TAWK_ID=

# Search-engine site verification (all optional - emit a <meta> tag if set).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
