# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (REQUIRED, server-only — never expose to the browser).
# Privileged writes and every PII/money table read go through this; without it
# admin, orders, payments, accounts, and cron routes cannot function.
SUPABASE_SERVICE_ROLE_KEY=

# Admin login password (REQUIRED). Verified in src/lib/auth.ts. Rotate before
# handoff and deliver the new value via 1Password / signed PDF — never Telegram.
ADMIN_PASSWORD=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile bot protection (optional - public forms fail-open if unset).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: widget site key (browser). TURNSTILE_SECRET:
# server secret used to verify the token in src/lib/turnstile.ts. With both unset,
# forms still work (honeypot + rate limiter remain the gate).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Telegram Bot (optional - for inquiry notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Operational alerts (optional). Where reportServerError / alertDealer send
# critical alerts (cron failures, payment-callback errors, notify-fanout
# failures). Falls back to TELEGRAM_CHAT_ID when unset; set to route ops alerts
# to a separate channel from customer-lead notifications.
TELEGRAM_ERROR_CHAT_ID=

# Transactional email via Resend (optional - fail-open if unset).
# RESEND_API_KEY: from resend.com. EMAIL_FROM: a sender on a domain verified
# in Resend (e.g. "Tez Motors <noreply@tezmotors.uz>"). DEALER_EMAIL: inbox
# that receives new-lead alerts (fallback when Telegram is down).
RESEND_API_KEY=
EMAIL_FROM=
DEALER_EMAIL=

# Scheduled jobs (optional - allows manual runs if unset).
# Shared bearer secret between the app and the separate cron Worker
# (cron-worker/). The cron Worker fires /api/cron/* on a schedule with
# "Authorization: Bearer <CRON_SECRET>"; src/lib/cron/guard.ts verifies it.
# When unset, the cron routes allow unauthenticated manual runs (dev only).
CRON_SECRET=

# AI sales assistant (optional - fail-open to retrieval-only if unset).
# LLM_API_KEY enables the "Find my car" assistant. Defaults target the
# Anthropic Messages API; override LLM_API_URL / LLM_MODEL for another HTTP
# provider. Without a key, the assistant still returns real cars + a templated
# reply (no 500).
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=

# Customer OTP via Eskiz.uz SMS (optional - fail-open if unset).
# ESKIZ_EMAIL / ESKIZ_PASSWORD: credentials from your eskiz.uz account.
# ESKIZ_FROM: an approved sender alphaname (defaults to Eskiz "4546" test
# sender). When unset, the phone-login OTP is logged server-side instead of
# sent, so the flow stays testable in dev without burning SMS credits.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=

# Web Push (optional - account push notifications fail-open / render nothing if
# unset). Generate a VAPID P-256 keypair once (Web Crypto / any vapid tool).
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY: base64url, server-side signing.
# VAPID_SUBJECT: a "mailto:" contact for push services.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY: same public key, exposed to the browser so the
# PushManager can subscribe. Without these, the notification toggle is hidden.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Telegram inbound bot (optional - the webhook no-ops cleanly if unset).
# Reuses the existing TELEGRAM_BOT_TOKEN above for sending replies. This secret
# is the value you pass as secret_token to setWebhook; the webhook rejects any
# request whose X-Telegram-Bot-Api-Secret-Token header doesn't match it.
# One-time registration after deploy:
#   curl "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/setWebhook" \
#     -d url="https://tezmotors.uz/api/bot/telegram" \
#     -d secret_token="<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp inbound bot via Meta Cloud API (optional - webhook no-ops if unset).
# WHATSAPP_VERIFY_TOKEN: a value you choose; entered in the Meta app dashboard as
# the webhook verify token (GET handshake echoes hub.challenge when it matches).
# WHATSAPP_TOKEN: a permanent System User access token for the WhatsApp Business
# Account. WHATSAPP_PHONE_ID: the phone number id that sends replies.
# Setup: set the callback URL to https://<your-domain>/api/bot/whatsapp, verify
# with WHATSAPP_VERIFY_TOKEN, then subscribe the WABA to the "messages" field.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Payme (Paycom) online deposits (optional - ships dark if unset).
# PAYME_MERCHANT_ID / PAYME_MERCHANT_KEY: from the Payme merchant cabinet after
# onboarding. The key authenticates the JSON-RPC merchant endpoint
# (/api/payments/payme); without it auth fails closed and the endpoint is inert.
# NEXT_PUBLIC_PAYME_MERCHANT_ID: same merchant id, exposed to the browser so the
# "Pay deposit online" button renders. Without it the button is hidden.
# Configure the cabinet's account field as "order_id" and point the endpoint at
# https://<your-domain>/api/payments/payme.
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
NEXT_PUBLIC_PAYME_MERCHANT_ID=

# Click.uz online deposits (optional - second payment rail, ships dark if unset).
# CLICK_SERVICE_ID / CLICK_MERCHANT_ID: from the Click merchant cabinet after
# onboarding. CLICK_SECRET_KEY signs the Prepare/Complete callbacks
# (/api/payments/click); without it verifyClickSign fails closed and the endpoint
# is inert. NEXT_PUBLIC_CLICK_MERCHANT_ID: same merchant id, exposed to the browser
# so the "Pay with Click" button renders. Without it the button is hidden.
# In the cabinet, set the Prepare URL and Complete URL to
# https://<your-domain>/api/payments/click and the param name to "order_id".
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
NEXT_PUBLIC_CLICK_MERCHANT_ID=

# Analytics & live chat (all optional - fail-open / render nothing if unset).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN: domain registered in Plausible (loads the script).
# NEXT_PUBLIC_TAWK_ID: Tawk.to property/widget id "<propertyId>/<widgetId>".
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_TAWK_ID=

# Search-engine site verification (all optional - emit a <meta> tag if set).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
