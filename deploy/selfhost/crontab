# Self-host cron schedule — mirrors cron-worker/src/index.js (the Cloudflare
# source of truth). Loaded by the Docker "cron" sidecar (BusyBox crond), which
# also works as a plain host crontab if you self-host without Docker.
# Each line fires one guarded /api/cron/* route with the bearer secret.
0 1 * * *    sh /scripts/fire-cron.sh /api/cron/rates
30 3 * * *   sh /scripts/fire-cron.sh /api/cron/lead-digest
0 4 * * *    sh /scripts/fire-cron.sh /api/cron/follow-ups
0 */6 * * *  sh /scripts/fire-cron.sh /api/cron/price-watch-sweep
0 5 * * *    sh /scripts/fire-cron.sh /api/cron/otp-cleanup
30 6 * * *   sh /scripts/fire-cron.sh /api/cron/saved-search-alerts
0 7 * * *    sh /scripts/fire-cron.sh /api/cron/review-requests
20 */2 * * * sh /scripts/fire-cron.sh /api/cron/reservation-recovery
0 3 * * *    sh /scripts/fire-cron.sh /api/cron/ops-digest
30 4 * * *   sh /scripts/fire-cron.sh /api/cron/order-sla
30 5 * * *   sh /scripts/fire-cron.sh /api/cron/lead-nurture
0 6 * * 1    sh /scripts/fire-cron.sh /api/cron/inventory-aging
0 8 * * *    sh /scripts/fire-cron.sh /api/cron/service-reminders
0 5 1 * *    sh /scripts/fire-cron.sh /api/cron/monthly-report
0 7 * * 2    sh /scripts/fire-cron.sh /api/cron/win-back
15 4 * * *   sh /scripts/fire-cron.sh /api/cron/generate-tasks
45 4 * * *   sh /scripts/fire-cron.sh /api/cron/shipment-sla
0 * * * *    sh /scripts/fire-cron.sh /api/cron/marketing-poster
10 * * * *   sh /scripts/fire-cron.sh /api/cron/promotions-apply
0 9 * * 3    sh /scripts/fire-cron.sh /api/cron/warranty-expiry
