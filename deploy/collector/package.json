{
  "name": "tez-motors-collectors",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Off-Workers data collectors: OLX + Telegram market scrapers and a headless media extractor. Run on the dealer's box (Node 18+).",
  "scripts": {
    "extractor": "node extractor.mjs",
    "olx": "node olx-collector.mjs",
    "olx:crawlee": "node olx-crawlee.mjs",
    "alibaba": "node alibaba-crawlee.mjs",
    "olx:parts": "node olx-parts-crawlee.mjs",
    "autohome": "node autohome-crawlee.mjs",
    "autohome:recon": "node autohome-recon.mjs",
    "gonzo": "node gonzo-crawlee.mjs",
    "enrich": "node enrich-from-discovery.mjs",
    "proxy:check": "node proxy-check.mjs",
    "instagram": "node instagram-collector.mjs",
    "telegram": "node telegram-collector.mjs",
    "telegram:login": "node telegram-collector.mjs --login",
    "postinstall": "echo 'Run: npx playwright install chromium  (needed for extractor + OLX browser fallback)'"
  },
  "dependencies": {
    "crawlee": "^3.16.0",
    "playwright": "^1.48.0",
    "telegram": "^2.26.0"
  }
}
